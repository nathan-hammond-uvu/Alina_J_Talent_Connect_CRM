CRM_ENV=development

# Required when CRM_ENV=production
SECRET_KEY=replace-with-a-long-random-secret

# Storage backend: json, sqlite, postgres
CRM_STORAGE_BACKEND=json

# Required if CRM_STORAGE_BACKEND=postgres. Optional for sqlite.
DATABASE_URL=

# Set to 1/true/yes/on to seed database backends from DATA_JSON_PATH at startup.
CRM_AUTO_IMPORT=0

# Path to seed/migration JSON file.
DATA_JSON_PATH=data.json

# Local runtime settings (not used by Gunicorn on Render)
FLASK_DEBUG=0
HOST=127.0.0.1
PORT=5000
